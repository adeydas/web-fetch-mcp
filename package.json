{
  "name": "web-render-mcp",
  "version": "1.0.0",
  "description": "MCP server for rendering JavaScript web pages using Puppeteer",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "dev": "tsc --watch",
    "prepare": "npm run build"
  },
